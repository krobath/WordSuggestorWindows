<Window x:Class="WordSuggestorWindows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WordSuggestor Windows"
        Width="560"
        Height="68"
        MinWidth="560"
        MinHeight="68"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStyle="None"
        Icon="/Assets/AppIcon.png">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E6E9EF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DCE1EA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarIconButtonStyle}">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="SuggestionChipButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarIconButtonStyle}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#D3D7DE" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchTrack"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <Grid Margin="2">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="20"
                                         Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#2F6FED" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="94" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#E4E6EA" />
            <Setter Property="BorderBrush" Value="#E4E6EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="8"
                CornerRadius="16"
                Background="#F3F4F6"
                BorderBrush="#D3D7DE"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="ToolbarSurface"
                        Padding="10,9"
                        Background="Transparent"
                        MouseLeftButtonDown="ToolbarSurface_OnMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    CornerRadius="5"
                                    Background="White"
                                    BorderBrush="#CCD2DA"
                                    BorderThickness="0.6">
                                <Image Source="/Assets/AppIcon.png"
                                       Stretch="Uniform" />
                            </Border>

                            <ToggleButton Margin="0,0,10,0"
                                          IsChecked="{Binding IsGlobalCaptureEnabled, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}"
                                          ToolTip="Aktivér eller deaktiver globale forslag" />

                            <ComboBox Width="98"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarComboBoxStyle}" />

                            <Button Tag="wordList"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Word list manager"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="WL" />
                            </Button>

                            <Button Tag="import"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Importer markeret tekst til editoren"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="TXT" />
                            </Button>

                            <Button Tag="ocr"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="OCR / skærmudsnit"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="OCR" />
                            </Button>

                            <Button Tag="speechToText"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Tale til tekst"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="MIC" />
                            </Button>

                            <Button Tag="textToSpeech"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Oplæs markeret tekst"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="TTS" />
                            </Button>

                            <Button Tag="insights"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Fejlindsigter"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="INS" />
                            </Button>

                            <Button Tag="settings"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Indstillinger"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontSize="16"
                                           Text="&#xE713;" />
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="34"
                                Height="28"
                                Margin="12,0,0,0"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="{Binding ExpandCollapseToolTip}"
                                Click="ExpandCollapseButton_OnClick">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="15"
                                       Text="{Binding ExpandCollapseGlyph}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="12,0,12,12"
                        Background="Transparent"
                        Visibility="{Binding IsEditorExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Height="1"
                                Margin="0,0,0,10"
                                Background="#D7DBE2" />

                        <StackPanel Grid.Row="1"
                                    Margin="0,0,0,10"
                                    Orientation="Horizontal">
                            <Button Tag="cut"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Klip"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontSize="15"
                                           Text="&#xE8C6;" />
                            </Button>

                            <Button Tag="copy"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Kopiér"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontSize="15"
                                           Text="&#xE8C8;" />
                            </Button>

                            <Button Tag="paste"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Indsæt"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontSize="15"
                                           Text="&#xE77F;" />
                            </Button>

                            <Border Width="1"
                                    Height="18"
                                    Margin="4,0,10,0"
                                    Background="#D7DBE2" />

                            <Button Tag="coloring"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Farvekodning"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="Aa" />
                            </Button>

                            <Button Tag="semantic"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Semantik"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="SEM" />
                            </Button>

                            <Button Tag="punctuation"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Tegnsætning"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text=".,"
                                           />
                            </Button>

                            <Button Tag="refreshSuggestions"
                                    Style="{StaticResource CommandButtonStyle}"
                                    ToolTip="Opdater forslag"
                                    Click="EditorCommand_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           FontSize="15"
                                           Text="&#xE72C;" />
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                Background="#EEF1F6"
                                BorderBrush="#D7DCE5"
                                BorderThickness="1">
                            <Grid Margin="12">
                                <Border CornerRadius="10"
                                        Background="White"
                                        BorderBrush="#E3E7EF"
                                        BorderThickness="1">
                                    <TextBox x:Name="EditorTextBox"
                                             Padding="14"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="20"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             Text="{Binding EditorText, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="EditorTextBox_OnTextChanged"
                                             SelectionChanged="EditorTextBox_OnSelectionChanged"
                                             PreviewKeyDown="EditorTextBox_OnPreviewKeyDown" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,10,0,10"
                                Padding="10,8"
                                CornerRadius="10"
                                Background="#FAFBFC"
                                BorderBrush="#DCE0E7"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="#707B88"
                                           Text="Aa" />
                                <TextBlock Margin="6,0,14,0"
                                           Foreground="#707B88"
                                           Text="{Binding CharacterCount, StringFormat={}{0} tegn}" />
                                <TextBlock Foreground="#707B88"
                                           Text="≡" />
                                <TextBlock Margin="6,0,14,0"
                                           Foreground="#707B88"
                                           Text="{Binding WordCount, StringFormat={}{0} ord}" />
                                <TextBlock Foreground="#707B88"
                                           Text="⚠" />
                                <TextBlock Margin="6,0,14,0"
                                           Foreground="#707B88"
                                           Text="{Binding SpellingCount, StringFormat={}{0} stavefejl}" />
                                <TextBlock Foreground="#707B88"
                                           Text="◎" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="#707B88"
                                           Text="{Binding GrammarCount, StringFormat={}{0} grammatik/tegnsætning}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Padding="12"
                                CornerRadius="12"
                                Background="#FBFCFD"
                                BorderBrush="#DCE0E7"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#556070"
                                           Text="Separat ordforslagsboks" />
                                <TextBlock Margin="0,4,0,10"
                                           FontSize="11"
                                           Foreground="#7A8491"
                                           Text="{Binding SuggestionPlacementSummary}" />

                                <WrapPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#C26AF7" />
                                        <TextBlock Foreground="#707B88" Text="Substantiver: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#F45A85" />
                                        <TextBlock Foreground="#707B88" Text="Egennavne: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#2CBCCB" />
                                        <TextBlock Foreground="#707B88" Text="Verber: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#F5A14E" />
                                        <TextBlock Foreground="#707B88" Text="Tillægsord: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#758BFF" />
                                        <TextBlock Foreground="#707B88" Text="Biord: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,4,6,0" Fill="#5BC878" />
                                        <TextBlock Foreground="#707B88" Text="Pronomen: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Rectangle Width="14" Height="2" Margin="0,7,6,0" Fill="#E24A4A" />
                                        <TextBlock Foreground="#707B88" Text="Staveforslag: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Rectangle Width="14" Height="2" Margin="0,7,6,0" Fill="#4A7DF0" />
                                        <TextBlock Foreground="#707B88" Text="Semantik: 0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,14,6"
                                                Orientation="Horizontal">
                                        <Rectangle Width="14" Height="2" Margin="0,7,6,0" Fill="#4A7DF0" />
                                        <TextBlock Foreground="#707B88" Text="Tegnsætning: 0" />
                                    </StackPanel>
                                </WrapPanel>

                                <TextBlock Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#7A8491"
                                           Text="{Binding SuggestionPageSummary}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="#7A8491"
                                           Text="{Binding ProviderDescription}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

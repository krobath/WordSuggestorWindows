<Window x:Class="WordSuggestorWindows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:models="clr-namespace:WordSuggestorWindows.App.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WordSuggestor Windows"
        Width="560"
        Height="68"
        MinWidth="560"
        MinHeight="68"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStyle="None"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown"
        Icon="/Assets/AppIcon.png">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="LanguageFlagTemplate" DataType="{x:Type models:LanguageOption}">
            <Grid Width="23" Height="15">
                <Border CornerRadius="3"
                        BorderBrush="#C7CDD7"
                        BorderThickness="0.8"
                        Background="{Binding FlagPrimaryBrush}">
                    <Grid ClipToBounds="True">
                        <Grid x:Name="HorizontalTricolor" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Rectangle Grid.Row="0" Fill="{Binding FlagPrimaryBrush}" />
                            <Rectangle Grid.Row="1" Fill="{Binding FlagSecondaryBrush}" />
                            <Rectangle Grid.Row="2" Fill="{Binding FlagAccentBrush}" />
                        </Grid>

                        <Grid x:Name="VerticalTricolor" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Fill="{Binding FlagPrimaryBrush}" />
                            <Rectangle Grid.Column="1" Fill="{Binding FlagSecondaryBrush}" />
                            <Rectangle Grid.Column="2" Fill="{Binding FlagAccentBrush}" />
                        </Grid>

                        <Grid x:Name="NordicCross" Visibility="Collapsed" Background="{Binding FlagPrimaryBrush}">
                            <Rectangle Width="4"
                                       HorizontalAlignment="Left"
                                       Margin="6,0,0,0"
                                       Fill="{Binding FlagSecondaryBrush}" />
                            <Rectangle Height="4"
                                       VerticalAlignment="Center"
                                       Fill="{Binding FlagSecondaryBrush}" />
                        </Grid>

                        <Grid x:Name="NordicCrossDouble" Visibility="Collapsed" Background="{Binding FlagPrimaryBrush}">
                            <Rectangle Width="5"
                                       HorizontalAlignment="Left"
                                       Margin="5,0,0,0"
                                       Fill="{Binding FlagSecondaryBrush}" />
                            <Rectangle Height="5"
                                       VerticalAlignment="Center"
                                       Fill="{Binding FlagSecondaryBrush}" />
                            <Rectangle Width="3"
                                       HorizontalAlignment="Left"
                                       Margin="6,0,0,0"
                                       Fill="{Binding FlagAccentBrush}" />
                            <Rectangle Height="3"
                                       VerticalAlignment="Center"
                                       Fill="{Binding FlagAccentBrush}" />
                        </Grid>

                        <Grid x:Name="UsFlag" Visibility="Collapsed" Background="{Binding FlagSecondaryBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Rectangle Grid.Row="0" Fill="{Binding FlagPrimaryBrush}" />
                            <Rectangle Grid.Row="2" Fill="{Binding FlagPrimaryBrush}" />
                            <Rectangle Grid.Row="4" Fill="{Binding FlagPrimaryBrush}" />
                            <Rectangle Grid.Row="6" Fill="{Binding FlagPrimaryBrush}" />
                            <Border Width="10"
                                    Height="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{Binding FlagAccentBrush}">
                                <UniformGrid Rows="2" Columns="3" Margin="1">
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                    <Ellipse Width="0.9" Height="0.9" Fill="#FFFFFF" />
                                </UniformGrid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Ellipse Width="5"
                         Height="5"
                         Margin="0,1,1,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Fill="#F0A64A"
                         Stroke="#FFFFFF"
                         StrokeThickness="1"
                         Visibility="Collapsed">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPackAvailable}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding FlagPattern}" Value="HorizontalTricolor">
                    <Setter TargetName="HorizontalTricolor" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FlagPattern}" Value="VerticalTricolor">
                    <Setter TargetName="VerticalTricolor" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FlagPattern}" Value="NordicCross">
                    <Setter TargetName="NordicCross" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FlagPattern}" Value="NordicCrossDouble">
                    <Setter TargetName="NordicCrossDouble" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FlagPattern}" Value="UsFlag">
                    <Setter TargetName="UsFlag" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E8EAEE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D9DEE6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarIconButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#F9FAFC" />
            <Setter Property="BorderBrush" Value="#D9DDE5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F1F4F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E8EDF4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FBFCFD" />
            <Setter Property="BorderBrush" Value="#D8DDE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="11"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2F5F9" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EAF0F8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#AFC0D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#D3D7DE" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchTrack"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <Grid Margin="2">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="20"
                                         Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#2F6FED" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#E7E8EC" />
            <Setter Property="BorderBrush" Value="#D6DAE1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9">
                                <Grid>
                                    <ContentPresenter Margin="6,0,18,0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Margin="0,0,8,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="10"
                                               Foreground="#505A68"
                                               Text="&#xE70D;" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom">
                                <Border Margin="0,6,0,0"
                                        Padding="4"
                                        Background="#FFFFFF"
                                        BorderBrush="#D6DAE1"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#ECEEF2" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#AEB8C6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2F6" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E5ECF6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="8"
                CornerRadius="16"
                Background="#F3F4F6"
                BorderBrush="#D3D7DE"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="ToolbarSurface"
                        Padding="10,9"
                        Background="Transparent"
                        MouseLeftButtonDown="ToolbarSurface_OnMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    CornerRadius="5"
                                    Background="White"
                                    BorderBrush="#CCD2DA"
                                    BorderThickness="0.6">
                                <Image Source="/Assets/AppIcon.png"
                                       Stretch="Uniform" />
                            </Border>

                            <ToggleButton Margin="0,0,10,0"
                                          IsChecked="{Binding IsGlobalCaptureEnabled, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}"
                                          ToolTip="Aktiver eller deaktiver globale forslag" />

                            <ComboBox Width="58"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding LanguageOptions}"
                                      ItemTemplate="{StaticResource LanguageFlagTemplate}"
                                      ItemContainerStyle="{StaticResource ToolbarComboBoxItemStyle}"
                                      SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarComboBoxStyle}"
                                      ToolTip="{Binding SelectedLanguageOption.DisplayLabel}" />

                            <Button Tag="wordList"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Fagordslister"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE8D2;" />
                            </Button>

                            <Button Tag="import"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Importer markeret tekst til editoren"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE8C8;" />
                            </Button>

                            <Button Tag="ocr"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="OCR / skærmudsnit"
                                    Click="ToolbarAction_OnClick">
                                <Grid Width="16" Height="14">
                                    <Rectangle RadiusX="2"
                                               RadiusY="2"
                                               Stroke="#39424E"
                                               StrokeThickness="1.1"
                                               StrokeDashArray="2,1" />
                                    <Rectangle Width="8"
                                               Height="1.2"
                                               Margin="0,4,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Top"
                                               Fill="#39424E" />
                                    <Rectangle Width="6"
                                               Height="1.2"
                                               Margin="0,0,0,4"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Fill="#39424E" />
                                </Grid>
                            </Button>

                            <Button Tag="speechToText"
                                    Background="{Binding SpeechToTextButtonBackground}"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="{Binding SpeechToTextToolTip}"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE720;" />
                            </Button>

                            <Button Tag="textToSpeech"
                                    Background="{Binding TextToSpeechButtonBackground}"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="{Binding TextToSpeechToolTip}"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE767;" />
                            </Button>

                            <Button Tag="insights"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Fejlindsigter"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE9D2;" />
                            </Button>

                            <Button Tag="settings"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Indstillinger"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="#39424E" Text="&#xE713;" />
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="34"
                                Height="28"
                                Margin="12,0,0,0"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="{Binding ExpandCollapseToolTip}"
                                Click="ExpandCollapseButton_OnClick">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="15"
                                       Text="{Binding ExpandCollapseGlyph}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="12,0,12,12"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Visibility="{Binding IsEditorExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Height="1"
                                Margin="0,0,0,10"
                                Background="#D7DBE2" />

                        <Border Grid.Row="1"
                                Margin="0,0,0,8"
                                Padding="8"
                                CornerRadius="12"
                                Background="#FBFCFD"
                                BorderBrush="#DCE1E8"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Tag="cut" Style="{StaticResource CommandButtonStyle}" ToolTip="Klip" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE8C6;" />
                                    </Button>
                                    <Button Tag="copy" Style="{StaticResource CommandButtonStyle}" ToolTip="Kopier" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE8C8;" />
                                    </Button>
                                    <Button Tag="paste" Style="{StaticResource CommandButtonStyle}" ToolTip="Indsæt" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE77F;" />
                                    </Button>

                                    <Border Width="1" Height="20" Margin="4,0,10,0" Background="#D7DBE2" />

                                    <ToggleButton Tag="coloring" IsChecked="{Binding IsAnalyzerColoringEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Slå farvekodning til/fra" Click="EditorCommand_OnClick">
                                        <Grid Width="16" Height="16">
                                            <Rectangle Width="3.2"
                                                       Height="9.6"
                                                       RadiusX="0.8"
                                                       RadiusY="0.8"
                                                       Fill="#39424E"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="-38" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Path Data="M8,3 L12.2,1.6 L14.4,3.8 L10.2,5.4 Z"
                                                  Fill="#39424E"
                                                  Stretch="Fill"
                                                  Width="7.2"
                                                  Height="4.4"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top" />
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton Tag="semantic" IsChecked="{Binding IsSemanticDiagnosticsEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Slå semantik til/fra" Click="EditorCommand_OnClick">
                                        <Grid Width="16" Height="16">
                                            <Path Data="M5.2,2.2 C8.5,2.2 11.1,4.6 11.1,7.5 C11.1,8.7 10.7,9.7 10,10.6 C10.6,11 11,11.8 11.1,13 L9.6,13 C9.3,11.8 8.3,11.1 7,11.1 L5.9,11.1 L5.9,13 L4.2,13 L4.2,9.7 C3.4,9.2 2.9,8.4 2.8,7.4 C2.8,4.5 4.1,2.2 5.2,2.2 Z"
                                                  Fill="#39424E"
                                                  Stretch="Fill"
                                                  Width="9"
                                                  Height="11"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="2,1,0,0" />
                                            <Path Data="M8.5,4.5 C9.6,4.7 10.2,5.4 10.2,6.3 C10.2,7.1 9.7,7.7 8.9,8.1"
                                                  Stroke="#FFFFFF"
                                                  StrokeThickness="0.9"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Width="3.2"
                                                  Height="3.8"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="5.6,4,0,0" />
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton Tag="punctuation" IsChecked="{Binding IsPunctuationDiagnosticsEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Slå tegnsætning til/fra" Click="EditorCommand_OnClick">
                                        <Grid Width="16" Height="16">
                                            <TextBlock Text="&#x201F;"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#39424E"
                                                       FontFamily="Segoe UI Symbol"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,-1,0,0" />
                                        </Grid>
                                    </ToggleButton>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Tag="refreshSuggestions" Style="{StaticResource CommandButtonStyle}" ToolTip="Opdater forslag" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#39424E" Text="&#xE72C;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                Background="#EEF1F6"
                                BorderBrush="#D7DCE5"
                                BorderThickness="1">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="10" Background="White" BorderBrush="#E3E7EF" BorderThickness="1">
                                    <RichTextBox x:Name="EditorTextBox"
                                                 Padding="14"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="20"
                                                 AcceptsTab="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 TextChanged="EditorTextBox_OnTextChanged"
                                                 SelectionChanged="EditorTextBox_OnSelectionChanged"
                                                 PreviewKeyDown="EditorTextBox_OnPreviewKeyDown">
                                        <FlowDocument PagePadding="0">
                                            <Paragraph Margin="0" />
                                        </FlowDocument>
                                    </RichTextBox>
                                </Border>

                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,6,0,6"
                                Padding="12,4"
                                CornerRadius="8"
                                Background="#FAFBFC"
                                BorderBrush="#DCE0E7"
                                BorderThickness="1">
                            <ItemsControl ItemsSource="{Binding StatusMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#5C6775" Text="{Binding Icon}" />
                                            <TextBlock Margin="7,0,0,0" FontSize="11" FontWeight="SemiBold" Foreground="#3F4A57" Text="{Binding ValueText}" />
                                            <TextBlock Margin="4,0,16,0" FontSize="11" Foreground="#6F7A87" Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Row="4" Padding="10,7" CornerRadius="10" Background="#FBFCFD" BorderBrush="#DCE0E7" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#556070" Text="Tekstanalyse" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding AnalyzerLegendMetrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,12,3" Padding="0" Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid Margin="0,0,6,0" VerticalAlignment="Center">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding MarkerBrush}">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsesLineMarker}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <Rectangle Width="14" Height="2" Fill="{Binding MarkerBrush}">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsesLineMarker}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                        </Rectangle>
                                                    </Grid>
                                                    <TextBlock Foreground="#707B88">
                                                        <Run Text="{Binding Label}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding Count}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

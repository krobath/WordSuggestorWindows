<Window x:Class="WordSuggestorWindows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WordSuggestor Windows"
        Width="560"
        Height="68"
        MinWidth="560"
        MinHeight="68"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStyle="None"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown"
        Icon="/Assets/AppIcon.png">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E6E9EF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DCE1EA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarIconButtonStyle}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#F5F7FA" />
            <Setter Property="BorderBrush" Value="#D8DDE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EDF2F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E4EBF5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#F5F7FA" />
            <Setter Property="BorderBrush" Value="#D8DDE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EDF2F8" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5EEF8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#8EA9CF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#D3D7DE" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchTrack"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <Grid Margin="2">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="20"
                                         Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#2F6FED" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="94" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#E4E6EA" />
            <Setter Property="BorderBrush" Value="#E4E6EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="8"
                CornerRadius="16"
                Background="#F3F4F6"
                BorderBrush="#D3D7DE"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="ToolbarSurface"
                        Padding="10,9"
                        Background="Transparent"
                        MouseLeftButtonDown="ToolbarSurface_OnMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    CornerRadius="5"
                                    Background="White"
                                    BorderBrush="#CCD2DA"
                                    BorderThickness="0.6">
                                <Image Source="/Assets/AppIcon.png"
                                       Stretch="Uniform" />
                            </Border>

                            <ToggleButton Margin="0,0,10,0"
                                          IsChecked="{Binding IsGlobalCaptureEnabled, Mode=TwoWay}"
                                          Style="{StaticResource SwitchToggleButtonStyle}"
                                          ToolTip="Aktiver eller deaktiver globale forslag" />

                            <ComboBox Width="98"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarComboBoxStyle}" />

                            <Button Tag="wordList"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Word list manager"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="WL" />
                            </Button>

                            <Button Tag="import"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Importer markeret tekst til editoren"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="TXT" />
                            </Button>

                                    <Button Tag="ocr"
                                            Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="OCR / skærmudsnit"
                                            Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="OCR" />
                            </Button>

                            <Button Tag="speechToText"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Tale til tekst"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="MIC" />
                            </Button>

                            <Button Tag="textToSpeech"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Oplæs markeret tekst"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="TTS" />
                            </Button>

                            <Button Tag="insights"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Fejlindsigter"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="INS" />
                            </Button>

                            <Button Tag="settings"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    ToolTip="Indstillinger"
                                    Click="ToolbarAction_OnClick">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE713;" />
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="34"
                                Height="28"
                                Margin="12,0,0,0"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="{Binding ExpandCollapseToolTip}"
                                Click="ExpandCollapseButton_OnClick">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="15"
                                       Text="{Binding ExpandCollapseGlyph}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="12,0,12,12"
                        Background="Transparent"
                        VerticalAlignment="Stretch"
                        Visibility="{Binding IsEditorExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Height="1"
                                Margin="0,0,0,10"
                                Background="#D7DBE2" />

                        <Border Grid.Row="1"
                                Margin="0,0,0,8"
                                Padding="8"
                                CornerRadius="12"
                                Background="#FBFCFD"
                                BorderBrush="#DCE1E8"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Tag="cut" Style="{StaticResource CommandButtonStyle}" ToolTip="Klip" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8C6;" />
                                    </Button>
                                    <Button Tag="copy" Style="{StaticResource CommandButtonStyle}" ToolTip="Kopier" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8C8;" />
                                    </Button>
                                    <Button Tag="paste" Style="{StaticResource CommandButtonStyle}" ToolTip="Indsæt" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE77F;" />
                                    </Button>

                                    <Border Width="1" Height="20" Margin="4,0,10,0" Background="#D7DBE2" />

                                    <ToggleButton Tag="coloring" IsChecked="{Binding IsAnalyzerColoringEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Farvekodning" Click="EditorCommand_OnClick">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Farver" />
                                    </ToggleButton>
                                    <ToggleButton Tag="semantic" IsChecked="{Binding IsSemanticDiagnosticsEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Semantik" Click="EditorCommand_OnClick">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Semantik" />
                                    </ToggleButton>
                                    <ToggleButton Tag="punctuation" IsChecked="{Binding IsPunctuationDiagnosticsEnabled, Mode=OneWay}" Style="{StaticResource CommandToggleButtonStyle}" ToolTip="Tegnsætning" Click="EditorCommand_OnClick">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Tegnsætning" />
                                    </ToggleButton>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Tag="refreshSuggestions" Style="{StaticResource CommandButtonStyle}" ToolTip="Opdater forslag" Click="EditorCommand_OnClick">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE72C;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                Background="#EEF1F6"
                                BorderBrush="#D7DCE5"
                                BorderThickness="1">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="10" Background="White" BorderBrush="#E3E7EF" BorderThickness="1">
                                    <RichTextBox x:Name="EditorTextBox"
                                                 Padding="14"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="20"
                                                 AcceptsTab="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 TextChanged="EditorTextBox_OnTextChanged"
                                                 SelectionChanged="EditorTextBox_OnSelectionChanged"
                                                 PreviewKeyDown="EditorTextBox_OnPreviewKeyDown">
                                        <FlowDocument PagePadding="0">
                                            <Paragraph Margin="0" />
                                        </FlowDocument>
                                    </RichTextBox>
                                </Border>

                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,6,0,6"
                                Padding="12,4"
                                CornerRadius="8"
                                Background="#FAFBFC"
                                BorderBrush="#DCE0E7"
                                BorderThickness="1">
                            <ItemsControl ItemsSource="{Binding StatusMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#5C6775" Text="{Binding Icon}" />
                                            <TextBlock Margin="7,0,0,0" FontSize="11" FontWeight="SemiBold" Foreground="#3F4A57" Text="{Binding ValueText}" />
                                            <TextBlock Margin="4,0,16,0" FontSize="11" Foreground="#6F7A87" Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Row="4" Padding="10,7" CornerRadius="10" Background="#FBFCFD" BorderBrush="#DCE0E7" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#556070" Text="Tekstanalyse" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding AnalyzerLegendMetrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,12,3" Padding="0" Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid Margin="0,0,6,0" VerticalAlignment="Center">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding MarkerBrush}">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsesLineMarker}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <Rectangle Width="14" Height="2" Fill="{Binding MarkerBrush}">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsesLineMarker}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                        </Rectangle>
                                                    </Grid>
                                                    <TextBlock Foreground="#707B88">
                                                        <Run Text="{Binding Label}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding Count}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="WordSuggestorWindows.App.SuggestionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordSuggestor Suggestions"
        Width="292"
        Height="532"
        Background="Transparent"
        AllowsTransparency="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        PreviewKeyDown="SuggestionOverlayWindow_OnPreviewKeyDown"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="OverlayHeaderButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="#E7EDF5" />
            <Setter Property="BorderBrush" Value="#D0D9E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DDE7F4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#ECF2F9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E2EBF5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayPlacementToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="#E7EDF5" />
            <Setter Property="BorderBrush" Value="#D0D9E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DDE7F4" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D8E7F8" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#7197C8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="8"
            Padding="0"
            CornerRadius="14"
            Background="#F5F8FC"
            BorderBrush="#BFD0E4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="9,6,9,5"
                    Background="#EFF4FB"
                    CornerRadius="14,14,0,0"
                    BorderBrush="#D4DFEC"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#2D3035"
                                       Text="Forslag" />
                            <TextBlock Margin="7,3,0,0"
                                       FontSize="10"
                                       Foreground="#7A8491"
                                       Text="{Binding SuggestionPageSummary}" />
                        </StackPanel>
                        <TextBlock Margin="0,1,0,0"
                                   FontSize="10"
                                   Foreground="#7A8491"
                                   Text="{Binding SuggestionPanelCountSummary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <ToggleButton Style="{StaticResource OverlayPlacementToggleStyle}"
                                      IsChecked="{Binding IsStaticPlacementMode, Mode=OneWay}"
                                      ToolTip="Statisk placering"
                                      Click="StaticPlacementButton_OnClick">
                            <TextBlock FontSize="10"
                                       Text="&#x1F4CC;" />
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource OverlayPlacementToggleStyle}"
                                      IsChecked="{Binding IsFollowCaretPlacementMode, Mode=OneWay}"
                                      ToolTip="Follow-caret"
                                      Click="FollowCaretButton_OnClick">
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Text="A|" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="5,3,5,1"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding VisibleSuggestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,1,0,0"
                                    Padding="6,2"
                                    CornerRadius="7"
                                    BorderThickness="1"
                                    BorderBrush="{Binding BorderBrush}"
                                    Background="{Binding BackgroundBrush}"
                                    ToolTip="{Binding MatchKindHelpText}"
                                    PreviewMouseLeftButtonUp="SuggestionRow_OnPreviewMouseLeftButtonUp">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Width="28"
                                               Margin="0,1,6,0"
                                               FontSize="10"
                                               Foreground="#697585"
                                               Text="{Binding ShortcutLabel}" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#272B31"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Suggestion.Term, Mode=OneWay}" />
                                            <Run Text=" " />
                                            <Run Foreground="#6F7986"
                                                 FontWeight="Regular"
                                                 Text="{Binding KindInlineSummary, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,0"
                                                   FontSize="10"
                                                   Foreground="#697585"
                                                   Text="{Binding MetadataSummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasMetadataSummary, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource OverlayActionButtonStyle}"
                                                ToolTip="Læs ordet op"
                                                Click="SpeakButton_OnClick">
                                            <TextBlock FontSize="10"
                                                       Foreground="#556272"
                                                       Text="&#x1F50A;" />
                                        </Button>
                                        <Button Style="{StaticResource OverlayActionButtonStyle}"
                                                ToolTip="Vis ordinfo"
                                                Click="InfoButton_OnClick">
                                            <TextBlock FontSize="10"
                                                       Foreground="#556272"
                                                       Text="&#x24D8;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Padding="7,4"
                    CornerRadius="0,0,14,14"
                    Background="#EAF2FB"
                    BorderBrush="#D4DFEC"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="22"
                            Height="20"
                            Style="{StaticResource OverlayHeaderButtonStyle}"
                            Click="PreviousPageButton_OnClick">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="10"
                                   Text="&#xE76B;" />
                    </Button>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="9"
                                   Foreground="#65707C"
                                   HorizontalAlignment="Center"
                                   Text="Ctrl+1..0 vælger | Ctrl+Venstre/Højre skifter side" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="22"
                            Height="20"
                            Style="{StaticResource OverlayHeaderButtonStyle}"
                            Click="NextPageButton_OnClick">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="10"
                                   Text="&#xE76C;" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
